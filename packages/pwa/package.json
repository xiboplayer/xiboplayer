{
  "name": "@xiboplayer/pwa",
  "version": "0.7.12",
  "description": "Lightweight PWA Xibo Player with RendererLite",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && BUILD_SW=1 vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@xiboplayer/cache": "workspace:*",
    "@xiboplayer/core": "workspace:*",
    "@xiboplayer/crypto": "workspace:*",
    "@xiboplayer/renderer": "workspace:*",
    "@xiboplayer/schedule": "workspace:*",
    "@xiboplayer/settings": "workspace:*",
    "@xiboplayer/stats": "workspace:*",
    "@xiboplayer/sw": "workspace:*",
    "@xiboplayer/sync": "workspace:*",
    "@xiboplayer/utils": "workspace:*",
    "@xiboplayer/xmds": "workspace:*",
    "@xiboplayer/xmr": "workspace:*",
    "html2canvas": "^1.4.1",
    "nanoevents": "^9.1.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@types/node": "^25.5.0",
    "@types/xml2js": "^0.4.14",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "author": "Pau Aliagas <linuxnow@gmail.com>",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xibo-players/xiboplayer.git",
    "directory": "packages/pwa"
  },
  "homepage": "https://xiboplayer.org"
}
