{
  "name": "xiboplayer",
  "version": "0.3.0",
  "private": true,
  "description": "Xibo Player SDK - modular packages for digital signage",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build:pwa": "pnpm --filter @xiboplayer/pwa build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint",
    "lint:fix": "biome lint --fix"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@vitest/coverage-v8": "^4.1.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2",
    "vitest": "^4.1.3"
  },
  "author": "Pau Aliagas <linuxnow@gmail.com>",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xibo-players/xiboplayer.git"
  },
  "homepage": "https://xiboplayer.org"
}
